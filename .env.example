# Supabase設定
# Supabaseプロジェクトの設定画面から取得してください
# https://app.supabase.com/project/_/settings/api

# SupabaseプロジェクトのURL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabaseの匿名キー（anon key / public key）
VITE_SUPABASE_ANON_KEY=your-anon-key-here


# 使い方:
# 1. このファイルを .env にコピーしてください
#    cp .env.example .env
#
# 2. Supabaseプロジェクトから取得した値を設定してください
#
# 3. 開発サーバーを再起動してください
#    npm run dev
